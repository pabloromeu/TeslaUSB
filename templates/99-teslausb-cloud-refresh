#!/bin/bash
# NetworkManager dispatcher — "car arrived home" handler.
#
# Called automatically by NetworkManager when WiFi connects or reconnects.
# Triggers: video indexing → cloud sync (in background).
#
# This is the main automation trigger — the user parks at home,
# WiFi connects, and within ~60 seconds everything is fresh.
#
# Deployed to: /etc/NetworkManager/dispatcher.d/99-teslausb-cloud-refresh
# Must be executable: chmod +x

INTERFACE="$1"
ACTION="$2"

# Only act on wlan0 events
[ "$INTERFACE" = "wlan0" ] || exit 0

# Trigger on initial connect and on connectivity restoration
case "$ACTION" in
    up|connectivity-change)
        ;;
    *)
        exit 0
        ;;
esac

# For connectivity-change, only act when we have full connectivity
if [ "$ACTION" = "connectivity-change" ]; then
    CONNECTIVITY="${CONNECTIVITY_STATE:-unknown}"
    [ "$CONNECTIVITY" = "FULL" ] || exit 0
fi

GADGET_DIR="__GADGET_DIR__"
LOCK="/run/teslausb-wifi-handler.lock"

# Prevent multiple concurrent runs. The handler is bounded at
# ~one archive cycle + ~one indexer drain + small overhead, so
# treat any lock newer than 10 minutes as still-valid and skip
# this fire.
if [ -f "$LOCK" ]; then
    LOCK_AGE=$(( $(date +%s) - $(stat -c %Y "$LOCK" 2>/dev/null || echo 0) ))
    [ "$LOCK_AGE" -lt 600 ] && exit 0
fi
touch "$LOCK"

# Delay briefly to let the network stabilize
sleep 10

# Run the WiFi handler (indexes videos + syncs to cloud, non-blocking)
nice -n 19 /usr/bin/python3 "$GADGET_DIR/scripts/web/helpers/refresh_cloud_token.py" &

# Clean up lock after handler finishes (background)
HANDLER_PID=$!
(wait $HANDLER_PID 2>/dev/null; rm -f "$LOCK") &

exit 0
